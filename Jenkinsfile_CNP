def uploadCoreCaseDataDefinitions(environmentString) {
  node {
    checkout scm
    dir("${WORKSPACE}") {
      sh 'corepack yarn install'
      sh 'corepack yarn setup'
      ccdDefinitionFilePath = "${WORKSPACE}/target/appeal/xlsx/ccd-appeal-config-${environmentString}.xlsx"
      sh """
      set -e
      bin/utils/upload-ccd.sh -e ${environmentString}
      """
      steps.archiveArtifacts artifacts: "target/appeal/xlsx/ccd-appeal-config-${environmentString}.xlsx"
    }
  }
}

withPipeline(type, product, component) {
//  enableHighLevelDataSetup()
  loadVaultSecrets(secrets)

  onPR {
    env.ENVIRONMENT = "preview"
    env.NODE_TLS_REJECT_UNAUTHORIZED = "0"
    env.PR_NUMBER = "${CHANGE_ID}"
    env.DEFINITION_STORE_URL_BASE = "https://ccd-definition-store-ia-ccd-definitions-pr-${CHANGE_ID}.preview.platform.hmcts.net"
    env.CCD_DATA_STORE_URL = "https://ccd-data-store-api-ia-ccd-definitions-pr-${CHANGE_ID}.preview.platform.hmcts.net"

  }

  afterSuccess('checkout') {
    uploadCoreCaseDataDefinitions('aat')
    uploadCoreCaseDataDefinitions('prod')
  }

