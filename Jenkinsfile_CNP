#!groovy
properties([
    parameters([
        [$class: 'GithubProjectProperty', projectUrlStr: 'https://github.com/hmcts/ia-ccd-definitions.git'],
        pipelineTriggers([[$class: 'GitHubPushTrigger']])
    ])
])

@Library("Infrastructure")

def product = "ia"
def component = "ccd-definitions"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [

]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [$class     : 'AzureKeyVaultSecret',
   secretType : 'Secret',
   name       : secretName,
   version    : '',
   envVariable: envVar
  ]
}

withPipeline("nodejs", product, component) {
  loadVaultSecrets(secrets)

  after('test') {
    // enable yarn audit and send message on master branch only
    try {
      yarnBuilder.yarn('audit')
    } catch (error) {
      onMaster {
        slackSend(channel: '#ia-tech', color: 'warning', message: "Yarn Audit has detected vulnerabilities in ${env.JOB_NAME}. You can check if there are patches for them in the full report, build details here: <${env.RUN_DISPLAY_URL}|Build ${env.BUILD_DISPLAY_NAME}>.")
      }
    }
  }

  after('smoketest:preview') {
    env.CCD_DEF_BASE_URL="http://ia-ccd-definitions-pr-${CHANGE_ID}-ia-case"
    env.IA_CASE_API_URL=env.CCD_DEF_BASE_URL
    env.CCD_DEF_URL="http://ia-ccd-definitions-pr-${CHANGE_ID}-ccd-data-store-api"

    stageWithAgent('Generate preview CCD configuration', product) {
      yarnBuilder.yarn('setup')
      yarnBuilder.yarn('generate-excel-preview')
      steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'definitions/xlsx/ia-ccd-definitions-preview.xlsx'
    }
  }

  before('functionalTest:preview') {
    yarnBuilder.yarn('setup')
  }

  before('functionalTest:aat') {
    yarnBuilder.yarn('setup')
  }

  after('functionalTest:aat') {

    publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "ia-ccd-e2e-tests/reports/tests/functional/",
        reportFiles          : 'index.html',
        reportName           : 'IA - EXUI Functional Test Report'
    ])

  }

  println """done!""".stripIndent()
}
