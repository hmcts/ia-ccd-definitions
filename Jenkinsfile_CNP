      env.CCD_DATA_STORE_URL = "https://ccd-data-store-api-ia-case-api-pr-${CHANGE_ID}.preview.platform.hmcts.net"
    }
  }
  onMaster {
    env.ENVIRONMENT = "aat"
  }
  onDemo {
    env.ENVIRONMENT = "demo"
  }
  onPerftest {
    env.ENVIRONMENT = "perftest"
  }

  onIthc {
    env.ENVIRONMENT = "ithc"
  }

  before('highleveldatasetup') {
    yarnBuilder.yarn('setup')
    archiveCoreCaseDataDefinitions()
  }
}