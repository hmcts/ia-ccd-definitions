{
    "name": "ia-ccd-definitions",
    "version": "0.1",
    "private": true,
    "config": {
        "dev": {
            "iaCaseUrl": "http://ia-case-api:8090",
            "aacUrl": "http://manage-case-assignment:4454"
        },
        "preview": {
            "aacUrl": "http://aac-manage-case-assignment-aat.service.core-compute-aat.internal"
        },
        "demo": {
            "iaCaseUrl": "http://ia-case-api-demo.service.core-compute-demo.internal",
            "aacUrl": "http://aac-manage-case-assignment-demo.service.core-compute-demo.internal"
        },
        "ithc": {
            "iaCaseUrl": "http://ia-case-api-ithc.service.core-compute-ithc.internal",
            "aacUrl": "http://aac-manage-case-assignment-ithc.service.core-compute-ithc.internal"
        },
        "perftest": {
            "iaCaseUrl": "http://ia-case-api-perftest.service.core-compute-perftest.internal",
            "aacUrl": "http://aac-manage-case-assignment-perftest.service.core-compute-perftest.internal"
        },
        "aat": {
            "iaCaseUrl": "http://ia-case-api-aat.service.core-compute-aat.internal",
            "aacUrl": "http://aac-manage-case-assignment-aat.service.core-compute-aat.internal"
        },
        "prod": {
            "iaCaseUrl": "http://ia-case-api-prod.service.core-compute-prod.internal",
            "aacUrl": "http://aac-manage-case-assignment-prod.service.core-compute-prod.internal"
        }
    },
    "scripts": {
        "test:smoke": "MOCHAWESOME_REPORTFILENAME=smoke-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @smoke --verbose --reporter mocha-multi --verbose",
        "test:LegalRepCreatesDetainedRepresented": "MOCHAWESOME_REPORTFILENAME=LegalRepCreatesDetainedRepresented-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @LegalRepDetainedRepresented --reporter mocha-multi --verbose",
        "test:LegalAdminCreatesDetainedAppellantInPerson": "MOCHAWESOME_REPORTFILENAME=LegalAdminCreatesDetainedAppellantInPerson-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @LegalAdminDetainedAppellantInPerson --reporter mocha-multi --verbose",
        "test:NonDetainedToDetainedRepresented": "MOCHAWESOME_REPORTFILENAME=NonDetainedToDetainedRepresented-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @NonDetainedToDetainedRepresented --reporter mocha-multi --verbose",
        "test:OutOfCountryLegalRepresented": "MOCHAWESOME_REPORTFILENAME=OutOfCountryLegalRepresented-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @OutOfCountryLegalRepresented --reporter mocha-multi --verbose",
        "test:LegalAdminDetainedRepresentedThenRemoveDetainedStatus": "MOCHAWESOME_REPORTFILENAME=LegalAdminDetainedRepresentedThenRemoveDetainedStatus-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @LegalAdminDetainedRepresented --reporter mocha-multi --verbose",
        "test:DetainedToNonDetained": "MOCHAWESOME_REPORTFILENAME=DetainedToNonDetained-$(date \"+%Y-%m-%d_%H-%M-%S\") npx codeceptjs run --grep @DetainedToNonDetained --reporter mocha-multi --verbose",
        "clean": "rm -rf target/",
        "decrypt": "node bin/decrypt.js",
        "copy-json": "bin/copy-json.sh",
        "setup": "bin/setup.sh",
        "generate-json": "bin/generate-json.sh",
        "generate-excel": "bin/generate-excel.sh",
        "generate": "bin/generate-ccd-definition.sh",
        "generate-dev": "bin/generate-ccd-definition.sh -e dev && node bin/case-event-to-fields-duplicate-checker.js && node bin/check-missing-system-user-fields.js && node bin/auth-casefield-duplicate-checker.js",
        "generate-preview": "bin/generate-ccd-definition.sh -e preview -p $PR_NUMBER",
        "generate-mirrord": "bin/generate-ccd-definition.sh -e mirrord",
        "generate-mirrord-user": "bin/generate-ccd-definition.sh -e mirrord -u $USERNAME",
        "generate-demo": "bin/generate-ccd-definition.sh -e demo",
        "generate-ithc": "bin/generate-ccd-definition.sh -e ithc",
        "generate-perftest": "bin/generate-ccd-definition.sh -e perftest",
        "generate-aat": "bin/generate-ccd-definition.sh -e aat",
        "generate-prod": "bin/generate-ccd-definition.sh -e prod",
        "generate-all": "yarn generate-dev && yarn generate-demo && yarn generate-ithc && yarn generate-perftest && yarn generate-aat && yarn generate-prod",
        "upload": "yarn generate-dev && USER_TOKEN=$(${CCD_DOCKER_PATH}/bin/idam-user-token.sh) && SERVICE_TOKEN=$(${CCD_DOCKER_PATH}/bin/idam-service-token.sh) && curl http://127.0.0.1:4451/import -H \"Authorization: Bearer ${USER_TOKEN}\" -H \"ServiceAuthorization: Bearer ${SERVICE_TOKEN}\" -F file=\"@target/appeal/xlsx/ccd-appeal-config-dev.xlsx\" && echo ''",
        "upload-wa": "yarn generate-dev && USER_TOKEN=$(${WA_KUBE_ENV_PATH}/scripts/actions/idam-user-token.sh) && SERVICE_TOKEN=$(${WA_KUBE_ENV_PATH}/scripts/actions/idam-service-token.sh) && curl http://ccd-definition-store-api/import -H \"Authorization: Bearer ${USER_TOKEN}\" -H \"ServiceAuthorization: Bearer ${SERVICE_TOKEN}\" -F file=\"@target/appeal/xlsx/ccd-appeal-config-dev.xlsx\" && echo ''",
        "upload-ccd": "bin/utils/upload-ccd.sh",
        "upload-mirrord": "bin/utils/upload-ccd.sh -e mirrord",
        "upload-preview": "bin/utils/upload-ccd.sh -e preview -p $PR_NUMBER",
        "create-state-diagram": "generateStateDiagram ./definitions/appeal/json/ -s=ended,appealTakenOffline -e=shareACase",
        "codeceptjs": "codeceptjs run --steps",
        "codeceptjs:headless": "HEADLESS=true codeceptjs run --steps"
    },
    "dependencies": {
        "@codeceptjs/expect-helper": "^1.0.2",
        "@hmcts/ia-state-diagram-tool": "^0.0.5",
        "config": "^3.0.1",
        "crypto-js": "3.1.9-1",
        "moment": "^2.30.1",
        "pre-commit": "^1.2.2",
        "prettier": "^1.17.0",
        "pretty-quick": "^1.10.0"
    },
    "packageManager": "yarn@3.4.1",
    "devDependencies": {
        "@codeceptjs/configure": "^1.0.4",
        "@codeceptjs/examples": "^1.2.4",
        "@codeceptjs/ui": "^1.2.4",
        "@types/node": "^22.15.16",
        "codeceptjs": "^3.7.3",
        "codeceptjs-a11y-helper": "^1.5.9",
        "mocha": "^11.2.2",
        "mocha-multi": "^1.1.7",
        "mochawesome": "^7.1.3",
        "playwright": "^1.52.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3"
    }
}
