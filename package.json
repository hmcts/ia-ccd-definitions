{
  "name": "ia-ccd-definitions",
  "version": "0.1",
  "private": true,
  "config": {
    "dev": {
      "iaCaseUrl": "http://ia-case-api:8090",
      "aacUrl": "http://manage-case-assignment:4454"
    },
    "preview": {
      "iaCaseUrl": "http://ia-case-api-pr-2078-java",
      "aacUrl": "http://aac-manage-case-assignment-aat.service.core-compute-aat.internal"
    },
    "demo": {
      "iaCaseUrl": "http://ia-case-api-demo.service.core-compute-demo.internal",
      "aacUrl": "http://aac-manage-case-assignment-demo.service.core-compute-demo.internal"
    },
    "ithc": {
      "iaCaseUrl": "http://ia-case-api-ithc.service.core-compute-ithc.internal",
      "aacUrl": "http://aac-manage-case-assignment-ithc.service.core-compute-ithc.internal"
    },
    "perftest": {
      "iaCaseUrl": "http://ia-case-api-perftest.service.core-compute-perftest.internal",
      "aacUrl": "http://aac-manage-case-assignment-perftest.service.core-compute-perftest.internal"
    },
    "aat": {
      "iaCaseUrl": "http://ia-case-api-aat.service.core-compute-aat.internal",
      "aacUrl": "http://aac-manage-case-assignment-aat.service.core-compute-aat.internal"
    },
    "prod": {
      "iaCaseUrl": "http://ia-case-api-prod.service.core-compute-prod.internal",
      "aacUrl": "http://aac-manage-case-assignment-prod.service.core-compute-prod.internal"
    }
  },
  "scripts": {
    "clean": "rm -rf target/",
    "decrypt": "node bin/decrypt.js",
    "copy-json": "bin/copy-json.sh",
    "setup": "bin/setup.sh",
    "generate-json": "bin/generate-json.sh",
    "generate-excel": "bin/generate-excel.sh",
    "generate-dev": "bin/generate-dev.sh",
    "generate-preview": "bin/generate-preview.sh",
    "generate-demo": "bin/generate-demo.sh",
    "generate-ithc": "bin/generate-ithc.sh",
    "generate-perftest": "bin/generate-perftest.sh",
    "generate-aat": "bin/generate-aat.sh",
    "generate-prod": "bin/generate-prod.sh",
    "generate-all": "yarn generate-dev && yarn generate-demo && yarn generate-ithc && yarn generate-perftest && yarn generate-aat && yarn generate-prod",
    "upload": "yarn generate-dev && USER_TOKEN=$(${CCD_DOCKER_PATH}/bin/idam-user-token.sh) && SERVICE_TOKEN=$(${CCD_DOCKER_PATH}/bin/idam-service-token.sh) && curl http://127.0.0.1:4451/import -H \"Authorization: Bearer ${USER_TOKEN}\" -H \"ServiceAuthorization: Bearer ${SERVICE_TOKEN}\" -F file=\"@target/appeal/xlsx/ccd-appeal-config-dev.xlsx\" && echo '' &&  node bin/caseEventToFieldsDuplicateChecker.js",
    "upload-wa": "yarn generate-dev && USER_TOKEN=$(${WA_KUBE_ENV_PATH}/scripts/actions/idam-user-token.sh) && SERVICE_TOKEN=$(${WA_KUBE_ENV_PATH}/scripts/actions/idam-service-token.sh) && curl http://ccd-definition-store-api/import -H \"Authorization: Bearer ${USER_TOKEN}\" -H \"ServiceAuthorization: Bearer ${SERVICE_TOKEN}\" -F file=\"@target/appeal/xlsx/ccd-appeal-config-dev.xlsx\" && echo ''",
    "create-state-diagram": "generateStateDiagram ./definitions/appeal/json/ -s=ended,appealTakenOffline -e=shareACase"
  },
  "dependencies": {
    "@hmcts/ia-state-diagram-tool": "^0.0.5",
    "config": "^3.0.1",
    "crypto-js": "3.1.9-1",
    "pre-commit": "^1.2.2",
    "prettier": "^1.17.0",
    "pretty-quick": "^1.10.0"
  },
  "packageManager": "yarn@3.4.1"
}
